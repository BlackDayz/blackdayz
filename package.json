{
  "name": "blackdayz-website",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=23.0.0"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
